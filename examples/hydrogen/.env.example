# Shopify Headless channel
PUBLIC_STORE_DOMAIN=store.myshopify.com
PUBLIC_CHECKOUT_DOMAIN=store.myshopify.com
PUBLIC_STOREFRONT_ID=your-storefront-id
PUBLIC_STOREFRONT_API_TOKEN=
PRIVATE_STOREFRONT_API_TOKEN=
PUBLIC_CUSTOMER_ACCOUNT_API_CLIENT_ID=
PUBLIC_CUSTOMER_ACCOUNT_API_URL=
SESSION_SECRET=

# Judge.me
JUDGEME_SHOP_DOMAIN=store.myshopify.com
JUDGEME_PUBLIC_TOKEN=
# Optional public Online Store page used to discover the current Judge.me extension.
JUDGEME_STOREFRONT_URL=https://store.myshopify.com/products/published-product
# Optional last-known-good fallback when storefront discovery is unavailable.
JUDGEME_V3_ASSET_BASE_URL=
# Server-only Shopify Admin token used to read Judge.me Trust Badge and, when
# Storefront visibility is unavailable, AI Reviews Summary metafields.
SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOPIFY_ADMIN_API_VERSION=2026-04
