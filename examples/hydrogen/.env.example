# Shopify Headless channel
PUBLIC_STORE_DOMAIN=vanilla-slop.myshopify.com
PUBLIC_CHECKOUT_DOMAIN=vanilla-slop.myshopify.com
PUBLIC_STOREFRONT_ID=303489
PUBLIC_STOREFRONT_API_TOKEN=
PRIVATE_STOREFRONT_API_TOKEN=
PUBLIC_CUSTOMER_ACCOUNT_API_CLIENT_ID=
