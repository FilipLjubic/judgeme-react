{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/bin/ctx-codex-hook.sh",
            "statusMessage": "Loading ctx grounding",
            "timeout": 30
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/bin/ctx-codex-hook.sh",
            "statusMessage": "Loading ctx memory",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/bin/ctx-codex-hook.sh",
            "statusMessage": "Recording ctx hook evidence",
            "timeout": 30
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/bin/ctx-codex-hook.sh",
            "statusMessage": "Recording ctx compaction",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/bin/ctx-codex-hook.sh",
            "statusMessage": "Recording ctx turn",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
