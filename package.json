{
  "name": "judgeme-react-workspace",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": "^22 || ^24"
  },
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "bun run build:library && bunx shopify hydrogen build --codegen --path examples/hydrogen",
    "build:library": "bun run --filter @judgeme-react/core build",
    "dev": "bun run build:library && bunx shopify hydrogen dev --codegen --port 3001 --path examples/hydrogen",
    "lint": "bun run --workspaces --sequential lint",
    "test": "bun run --filter @judgeme-react/core test",
    "typecheck": "bun run --workspaces --sequential typecheck"
  }
}
