{
  "name": "judgeme-react",
  "version": "1.0.4",
  "description": "React adapters for Judge.me widgets across Shopify headless storefronts.",
  "license": "MIT",
  "author": "Filip Ljubic",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FilipLjubic/judgeme-react.git",
    "directory": "packages/judgeme-react"
  },
  "homepage": "https://github.com/FilipLjubic/judgeme-react/tree/main/packages/judgeme-react#readme",
  "bugs": {
    "url": "https://github.com/FilipLjubic/judgeme-react/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "SETUP_PROMPT.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "default": "./dist/react.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "default": "./dist/server.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": "^22 || ^24"
  },
  "keywords": [
    "judge.me",
    "shopify",
    "hydrogen",
    "react",
    "reviews",
    "widgets"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "lint": "tsc --project tsconfig.build.json --noEmit",
    "pack:check": "bun pm pack --dry-run",
    "prepack": "bun run build",
    "prepublishOnly": "bun run release:check",
    "publint": "publint",
    "release:check": "bun run test && bun run lint && bun run pack:check && bun run publint",
    "test": "bun run build && node --test",
    "typecheck": "tsc --project tsconfig.build.json --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.3 <20"
  },
  "devDependencies": {
    "@types/react": "^18.3.28",
    "publint": "^0.3.21",
    "react": "^18.3.1",
    "typescript": "^5.9.2"
  }
}
