    "typecheck": "tsc --project tsconfig.build.json --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.3 <20"
  },
  "devDependencies": {
    "@types/react": "^18.3.28",
    "react": "^18.3.1",
    "typescript": "^5.9.2"
  }
}
